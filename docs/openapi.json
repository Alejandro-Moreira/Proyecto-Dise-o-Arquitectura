{
  "openapi": "3.0.3",
  "info": {
    "title": "EcoFirma API Gateway",
    "version": "1.0.0",
    "description": "REST API exposed by the EcoFirma API Gateway for users, documents and asynchronous signatures."
  },
  "servers": [
    {
      "url": "http://localhost:8081",
      "description": "Local Docker deployment"
    }
  ],
  "tags": [
    {
      "name": "Users Service"
    },
    {
      "name": "Documents Service"
    },
    {
      "name": "Signature Service"
    }
  ],
  "paths": {
    "/api/users/register": {
      "post": {
        "tags": [
          "Users Service"
        ],
        "summary": "Register a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserRegisterRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/api/users/login": {
      "post": {
        "tags": [
          "Users Service"
        ],
        "summary": "Authenticate a user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserLoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "JWT token and user profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/documents": {
      "get": {
        "tags": [
          "Documents Service"
        ],
        "summary": "List documents",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Document list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DocumentResponse"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Documents Service"
        ],
        "summary": "Create a document",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DocumentCreateRequest"
              }
            },
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file",
                  "autorId"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "Document file (.pdf or .docx) to upload, max 40MB"
                  },
                  "autorId": {
                    "type": "string",
                    "description": "Identifier of the author user"
                  },
                  "titulo": {
                    "type": "string",
                    "description": "Optional title of the document (defaults to filename if omitted)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Document created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "413": {
            "description": "Payload Too Large (file exceeds 40MB)"
          }
        }
      }
    },
    "/api/documents/{id}": {
      "get": {
        "tags": [
          "Documents Service"
        ],
        "summary": "Get document by ID",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/DocumentId"
          }
        ],
        "responses": {
          "200": {
            "description": "Document found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "put": {
        "tags": [
          "Documents Service"
        ],
        "summary": "Update a document",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/DocumentId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DocumentUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Document updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "tags": [
          "Documents Service"
        ],
        "summary": "Delete a document",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/DocumentId"
          }
        ],
        "responses": {
          "204": {
            "description": "Document deleted"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/documents/{id}/status": {
      "get": {
        "tags": [
          "Documents Service"
        ],
        "summary": "Get document signature status",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/DocumentId"
          }
        ],
        "responses": {
          "200": {
            "description": "Current document status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentStatusResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/signatures/process": {
      "post": {
        "tags": [
          "Signature Service"
        ],
        "summary": "Start asynchronous signature processing",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignatureProcessRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Signature processing accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SignatureProcessResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "503": {
            "description": "Queue unavailable"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "DocumentId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Conflict": {
        "description": "Resource conflict",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "UserRegisterRequest": {
        "type": "object",
        "required": [
          "nombre",
          "email",
          "password"
        ],
        "properties": {
          "nombre": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "format": "password"
          }
        }
      },
      "UserLoginRequest": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "format": "password"
          }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "nombre": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/UserResponse"
          }
        }
      },
      "DocumentCreateRequest": {
        "type": "object",
        "required": [
          "titulo",
          "contenidoBase64",
          "autorId"
        ],
        "properties": {
          "titulo": {
            "type": "string"
          },
          "contenidoBase64": {
            "type": "string"
          },
          "autorId": {
            "type": "string"
          }
        }
      },
      "DocumentUpdateRequest": {
        "type": "object",
        "properties": {
          "titulo": {
            "type": "string"
          },
          "contenidoBase64": {
            "type": "string"
          }
        }
      },
      "DocumentResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "titulo": {
            "type": "string"
          },
          "contenidoBase64": {
            "type": "string"
          },
          "autorId": {
            "type": "string"
          },
          "estado": {
            "$ref": "#/components/schemas/DocumentStatus"
          },
          "status": {
            "$ref": "#/components/schemas/DocumentStatus"
          },
          "archivoNombre": {
            "type": "string",
            "nullable": true,
            "description": "Original filename of the uploaded file"
          },
          "archivoTamano": {
            "type": "integer",
            "nullable": true,
            "description": "File size in bytes"
          },
          "archivoTipo": {
            "type": "string",
            "nullable": true,
            "description": "MimeType of the uploaded file"
          }
        }
      },
      "DocumentStatus": {
        "type": "string",
        "enum": [
          "PENDIENTE",
          "EN_PROCESO",
          "FIRMADO",
          "ERROR"
        ]
      },
      "DocumentStatusResponse": {
        "type": "object",
        "properties": {
          "documentId": {
            "type": "string"
          },
          "estado": {
            "$ref": "#/components/schemas/DocumentStatus"
          },
          "status": {
            "$ref": "#/components/schemas/DocumentStatus"
          }
        }
      },
      "SignatureProcessRequest": {
        "type": "object",
        "required": [
          "documentId"
        ],
        "properties": {
          "documentId": {
            "type": "string"
          }
        }
      },
      "SignatureProcessResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "documentId": {
            "type": "string"
          },
          "estado": {
            "$ref": "#/components/schemas/DocumentStatus"
          },
          "status": {
            "$ref": "#/components/schemas/DocumentStatus"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    }
  }
}