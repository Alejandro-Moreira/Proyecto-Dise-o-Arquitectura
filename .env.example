# ============================================================
# EcoFirma - Variables de entorno (copia este archivo a .env)
# ============================================================

# PostgreSQL
POSTGRES_USER=ecofirma_user
POSTGRES_PASSWORD=ecofirma_secret_password
POSTGRES_DB=ecofirma_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TTL=300

# RabbitMQ
RABBITMQ_USER=ecofirma_rabbit
RABBITMQ_PASSWORD=ecofirma_rabbit_password
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# JWT
JWT_SECRET=super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=1h

# Servicios internos (resolucion por nombre de contenedor Docker)
USERS_SERVICE_URL=http://users-service:3001
DOCUMENTS_SERVICE_URL=http://documents-service:3002

# Secreto compartido para comunicacion interna entre servicios
INTERNAL_TOKEN=ecofirma_internal_shared_secret_token

# Puertos expuestos (host)
GATEWAY_PORT=8080
USERS_SERVICE_PORT=3001
DOCUMENTS_SERVICE_PORT=3002
